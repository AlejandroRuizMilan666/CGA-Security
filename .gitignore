# ── Dependencies ──────────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
.pnp
.pnp.*

# ── Build outputs ─────────────────────────────────────────────────────
backend/dist/
frontend/.next/
frontend/out/
frontend/build/

# ── Environment variables (NEVER commit secrets) ──────────────────────
.env
.env.*
!.env.example
!.env.*.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ── Logs ──────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Testing & coverage ────────────────────────────────────────────────
coverage/
backend/coverage/
frontend/coverage/
*.lcov
.nyc_output/

# ── TypeScript ────────────────────────────────────────────────────────
*.tsbuildinfo
backend/*.tsbuildinfo
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ── Prisma ────────────────────────────────────────────────────────────
# Keep migrations and schema, ignore generated client
backend/src/generated/
backend/node_modules/.prisma/

# ── Docker ────────────────────────────────────────────────────────────
# Keep docker-compose.yml, ignore override files with secrets
docker-compose.override.yml
docker-compose.*.yml
!docker-compose.yml

# ── OS & editor artifacts ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/settings.json
.vscode/launch.json

# ── Uploads / user-generated content ─────────────────────────────────
backend/uploads/
backend/temp/
